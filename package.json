{
	"name": "cho",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "."
	},
	"scripts": {
		"prepare": "husky",
		"cho:dev": "cargo run -p cho-cli --",
		"build": "bash scripts/build.sh",
		"build:unsigned": "CHO_CODESIGN_DISABLE=1 bash scripts/build.sh",
		"util:codesign:status": "bash scripts/macos-codesign-status.sh",
		"util:codesign:reset-keychain": "bash scripts/macos-keychain-reset.sh",
		"util:format": "cargo fmt --all",
		"util:lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
		"util:types": "cargo check --workspace",
		"util:test": "cargo test --workspace",
		"util:build": "cargo build --workspace",
		"util:check": "bun run util:format && bun run util:lint && bun run util:types && bun run util:test && bun run util:build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@typescript/native-preview": "^7.0.0-dev.20260226.1",
		"bun-types": "^1.3.10",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7"
	}
}
